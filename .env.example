# Vega — environment variables. Copy to `.env` and fill in.

# Deepgram streaming STT API key.
# Get one at https://console.deepgram.com/.
DEEPGRAM_API_KEY=

# Anthropic API key for the LLM orchestration layer.
# Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Core daemon — optional overrides.
EAR_WS_HOST=127.0.0.1
EAR_WS_PORT=7777
DEEPGRAM_LANGUAGE=ru
SESSION_TIMEOUT_MS=30000
# Defaults to <repo-root>/recordings if unset.
# RECORDINGS_DIR=
# Defaults to <recordings-dir>/vega.sqlite if unset.
# VEGA_DB_PATH=
# Set to 1 to ping the Anthropic API at boot to surface bad keys early.
# VEGA_LLM_PING_ON_BOOT=0
